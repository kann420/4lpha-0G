# --- V3 Policy Vault (Zia LP native) ---
# NOTE: There is intentionally NO on-chain V3 factory on 0G mainnet
# (PolicyVaultFactoryV3 exceeds EIP-170's 24KB cap). V3 vaults are deployed as
# singletons via scripts/create-mainnet-vault-v3.ts and tracked in an off-chain
# registry (.data/deployments/mainnet-policy-vault-v3-registry.json).
# NEXT_PUBLIC_POLICY_VAULT_FACTORY_V3_* are reserved for EDR/local tests only.
POLICY_VAULT_V3_ADDRESS=
POLICY_VAULT_V3_MAINNET_ADDRESS=
NEXT_PUBLIC_POLICY_VAULT_V3_ADDRESS=
NEXT_PUBLIC_POLICY_VAULT_V3_MAINNET_ADDRESS=
NEXT_PUBLIC_POLICY_VAULT_FACTORY_V3_ADDRESS=
NEXT_PUBLIC_POLICY_VAULT_FACTORY_V3_MAINNET_ADDRESS=
NEXT_PUBLIC_POLICY_VAULT_FACTORY_V3_FROM_BLOCK=
NEXT_PUBLIC_POLICY_VAULT_FACTORY_V3_MAINNET_FROM_BLOCK=
POLICY_VAULT_ZIA_LP_ADAPTER_ADDRESS=
POLICY_VAULT_ZIA_LP_ADAPTER_MAINNET_ADDRESS=
NEXT_PUBLIC_POLICY_VAULT_ZIA_LP_ADAPTER_MAINNET_ADDRESS=
# Zia V3 contract addresses (public mainnet, address-only — safe to pre-fill;
# mirrors of constants in lib/contracts/zia-lp.ts).
NEXT_PUBLIC_ZIA_NFT_POSITION_MANAGER_MAINNET_ADDRESS=0x5143ba6007C197b4cF66c20601b9dB97E0F98c6A
NEXT_PUBLIC_ZIA_SWAP_ROUTER_MAINNET_ADDRESS=0x18cCa38E51c4C339A6BD6e174025f08360FEEf30
NEXT_PUBLIC_ZIA_QUOTER_V2_MAINNET_ADDRESS=0x23b55293b7F06F6c332a0dDA3D88d8921218425B
NEXT_PUBLIC_ZIA_UNISWAP_V3_FACTORY_MAINNET_ADDRESS=0x6F3945Ab27296D1D66D8EEb042ff1B4fb2E0CE70
# W0G is reused from NEXT_PUBLIC_POLICY_VAULT_WRAPPED_NATIVE_MAINNET_ADDRESS above (do not duplicate).
MAINNET_ALLOW_MOCK_LP_ADAPTER=false
MAINNET_CREATE_VAULT_V3=false
# Force-flag for scripts/create-mainnet-vault-v3.ts. Required when the off-chain
# V3 registry (.data/deployments/mainnet-policy-vault-v3-registry.json) is missing
# or empty: there is NO on-chain V3 factory on 0G mainnet (PolicyVaultFactoryV3
# exceeds EIP-170's 24KB cap), so the deploy script cannot otherwise detect a V3
# already deployed for the same owner from another branch/machine. Leave false
# for normal deploys; set true ONLY when intentionally redeploying without a registry.
MAINNET_V3_REDEPLOY_FORCE=false
# Gate for scripts/deploy-mainnet-zia-lp-adapter.ts. Leave false for dry-run (verifies
# gates + bytecode of NFPM/swapRouter/W0G/zappable Zia vaults, sends no tx). Set true
# to deploy the no-arg ZiaLpAdapter singleton from the deployer wallet.
MAINNET_DEPLOY_ZIA_LP_ADAPTER=false
# Force-flag for scripts/deploy-mainnet-zia-lp-adapter.ts. Refuses a second adapter
# deploy when NEXT_PUBLIC_POLICY_VAULT_ZIA_LP_ADAPTER_MAINNET_ADDRESS already has live
# bytecode. Set true ONLY when intentionally deploying a replacement adapter.
MAINNET_ZIA_LP_ADAPTER_REDEPLOY_FORCE=false

# --- V4 Policy Vault (three-way per-user split) ---
# Shared infrastructure only. Per-user V4 vault thirds deploy from the UI with
# the user's wallet; do not add hardhat per-user deploy env vars.
NEXT_PUBLIC_POLICY_VAULT_V4_REGISTRY_MAINNET_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_VAULT_REGISTRY_V4_MAINNET_FROM_BLOCK=0
NEXT_PUBLIC_POLICY_VAULT_ZIA_LP_ADAPTER_V4_MAINNET_ADDRESS=0x0000000000000000000000000000000000000000
POLICY_VAULT_V3_MAINNET_FROM_BLOCK=
NEXT_PUBLIC_POLICY_VAULT_V3_MAINNET_FROM_BLOCK=
MAINNET_DEPLOY_ZIA_LP_ADAPTER_V4=false

# --- V3 LP policy (read by scripts/create-mainnet-vault-v3.ts via readV3PolicyFromEnv) ---
NEXT_PUBLIC_POLICY_VAULT_V3_MAINNET_PER_LP_ACTION_CAP_0G=2
NEXT_PUBLIC_POLICY_VAULT_V3_MAINNET_LP_DAILY_CAP_0G=10
NEXT_PUBLIC_POLICY_VAULT_V3_MAINNET_MAX_LP_EXPOSURE_0G=15
NEXT_PUBLIC_POLICY_VAULT_V3_MAINNET_LP_COOLDOWN_SECONDS=0
NEXT_PUBLIC_POLICY_VAULT_V3_MAINNET_LP_MIN_OUT_BPS=9500
NEXT_PUBLIC_POLICY_VAULT_V3_MAINNET_LP_MIN_LIQUIDITY_FLOOR=1000000
NEXT_PUBLIC_POLICY_VAULT_V3_MAINNET_LP_ALLOW_STAKING=true

# --- LP Agent mainnet gate (lib/agent/lp/lp-env-gate.ts) ---
# The LP Agent (mint AgenticID + tightenPolicy + depositNative + execute LP
# action) is mainnet-only. Required for BOTH deploy and execute:
#   OG_NETWORK=mainnet
#   OG_CHAIN_ID=16661   (NOT 16602 — Galileo is unsupported for LP)
#   ENABLE_MAINNET_DEPLOY=true
#   ENABLE_REAL_DEX_ADAPTER=true
#   ENABLE_MOCK_DEX_ADAPTER=false
#   MAINNET_ALLOW_MOCK_LP_ADAPTER=false
# Required for execute (live vault LP action that spends real 0G) only:
#   AGENT_TRADE_LIVE_ENABLED=true
# A mismatch (e.g. OG_NETWORK=mainnet with OG_CHAIN_ID=16602) returns
# `chain_id_mismatch` from the LP routes and aborts before any broadcast.

