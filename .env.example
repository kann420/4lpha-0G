# CoinMarketCap data layer for Copilot market-overview prompts (Hướng B).
# Server-only. CMC_API_KEY is reused from the Claude Code MCP wiring (.mcp.json);
# the Copilot chat route calls the CMC MCP HTTP endpoint server-side as grounded
# context for the 0G Compute Router — never as a reasoning path. Optional:
# leave CMC_API_KEY empty to disable market-data grounding (the framework prompt
# then tells the model data is unavailable instead of inventing numbers).
CMC_API_KEY=
CMC_MCP_BASE_URL=https://mcp.coinmarketcap.com/mcp

# Zia / TradeGPT partner API for 0G mainnet LP discovery, token pricing, and route planning.
# Keep the real base URL in .env.local or deployment secrets only. Do not commit
# partner-only endpoint URLs, keys, or full request examples to public files.
ZIA_TRADEGPT_API_BASE_URL=
ZIA_TRADEGPT_API_TIMEOUT_MS=10000

